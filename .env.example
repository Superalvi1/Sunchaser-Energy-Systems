# GEMINI_API_KEY: Required for Gemini AI Sunchaser assistant and scoring diagnostics.
# AI Studio automatically injects this from secrets panel at runtime.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: Injected automatically by AI Studio for routing.
APP_URL="YOUR_APP_URL"

# --- SUPABASE PRODUCTION DATABASE CONFIGURATIONS ---
# Configure these once you provision your database inside your Supabase.com dashboard.
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key-bypasses-rls-secure-backend"
SUPABASE_ANON_KEY="your-supabase-anon-key-public-client"

# JWT_SECRET: Private custom signature seed for session validation encoders.
JWT_SECRET="generate-a-random-secure-alphanumeric-secret-here-32-chars"
